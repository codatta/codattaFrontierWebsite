{
  "name": "vite-boilerplate",
  "private": true,
  "version": "1.0.0",
  "author": "yannick@chaintool.ai",
  "license": "ISC",
  "description": "A scaffolding for web front-end project development, particularly suitable for mobile applications.",
  "keywords": [
    "typescript",
    "react",
    "vite",
    "unocss",
    "vant"
  ],
  "type": "module",
  "scripts": {
