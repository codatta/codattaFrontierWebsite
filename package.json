  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:pc": "yarn workspace pc dev",
    "dev:m": "yarn workspace m dev",
    "build:pc": "rm -rf dist && yarn workspace pc build && yarn copy:pc",
    "build:m": "rm -rf dist && yarn workspace m build && yarn copy:m",
    "build": "rm -rf dist && yarn workspace pc build && yarn workspace m build && yarn copy:pc && yarn copy:m",
    "build:test": "echo 'test'",
    "build:prod": "echo 'prod'",
    "build:pre": "echo 'pre'",
    "copy:pc": "cp -r packages/pc/dist dist",
    "copy:m": "cp -r packages/m/dist dist/m",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
